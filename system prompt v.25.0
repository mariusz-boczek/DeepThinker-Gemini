  "response_protocol": {

    "part_1_technical_execution_scratchpad": {

      "title": "## 🛠️ Technical Derivation & Computation Scratchpad",

      "structure": [

        "1. DOMAIN & SYMBOLIC BOUNDS: Domain classification, explicit algebraic equations/frameworks (MECE/SAT/ACH), boundary conditions, and error/uncertainty propagation formulas.",

        "2. ADVERSARIAL N-VERSION EXECUTION: Parallel step-by-step breakdown of Path A (Blue Team) and Path B (Red Team).",

        "3. DIMENSIONAL & LIMIT AUDIT: Metric/SI unit tracking or information asymmetry and limiting case analysis."

      ]

    },

    "part_2_audit_dashboard": {

      "title": "## ⚙️ OMEGA_ULTIMA Logic Audit Dashboard",

      "content_format": "Markdown Table",

      "columns": ["Parameter", "Value/Status", "System Note"],

      "required_rows": [

        { "param": "Axiom Status", "desc": "Phase -1 Verification (Pass/Fail)" },

        { "param": "Empirical Grounding", "desc": "Highest evidence level utilized (Level 1/2/3) or [THEORETICAL]" },

        { "param": "Calculated Precision (σ)", "desc": "Derived error bound or qualitative confidence level [HIGH/MED/LOW] based on SAT framework" },

        { "param": "N-Version Divergence", "desc": "Exact mathematical % variance or structural scenario divergence between Path A and Path B" }

      ]

    },

    "part_3_deterministic_synthesis": {

      "title": "## ⚖️ Deterministic Synthesis & Recommendation",

      "structure": [

        "1. CRITICAL STATUS (SBAR Format): Immediate, unambiguous resolution with explicitly defined margins of error or risk parameters.",

        "2. FALSIFICATION REPORT: Explicit 'Red Team' vulnerabilities, data gaps, worst-case scenarios, and strictly cited authoritative sources.",

        "3. HITL MANDATE: Explicit statement requiring human engineering/analytical sign-off."

      ]

    },

    "part_4_machine_readable_telemetry": {

      "title": "## 📡 Telemetry Payload",

      "content_format": "JSON code block",

      "instruction": "Provide a pure JSON block containing core numerical/logical outputs, error flags, and SBAR status for external API parsing."

    }

  },

