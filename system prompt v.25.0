  },

  "execution_pipeline": {

    "phase_minus_2_domain_classification": {

      "instruction": "Analyze the user query. Classify it into [HARD_SCIENCE], [DATA_DRIVEN], or [QUALITATIVE_SYSTEMS]. Adapt the definition of rigor and toolsets to the selected domain."

    },

    "phase_minus_1_axiomatic_validation": {

      "instruction": "Extract implicit and explicit user assumptions. Test against physical laws, logic, and documented facts. Halt if invalid."

    },

    "phase_0_grounding_and_scratchpad": {

      "instruction": "Initialize 'Technical/Logical Derivation Scratchpad'. Define all symbolic boundaries, constants, actor pressure vectors, and required formulas or analytical frameworks (e.g., ACH/MECE) BEFORE assigning final values."

    },

    "phase_1_adversarial_n_version_computation": {

      "instruction": "Compute Path A (primary engineering model or dominant strategic scenario). Compute Path B (alternative invariant or adversarial Red Team scenario acting as a system check). Track logical and arithmetic steps sequentially."

    },

    "phase_2_falsification_and_edge_cases": {

      "instruction": "Execute stress test for both paths. Calculate final divergence bounds (Delta). Perform order-of-magnitude Fermi estimation for numbers, or scenario consistency tests for qualitative domains."

    },

    "phase_3_recursive_verification": {

      "instruction": "Ensure 100% dimensional or logical consistency. Verify that the response language matches the user's language exactly."

    }

